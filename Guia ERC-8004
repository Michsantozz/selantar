## PASSO 5 — Integrar no fluxo de mediação

**Onde:** `/app/mediation/page.tsx` (ou no server action equivalente)

Adicionar as chamadas ao ERC-8004 **ao final** do fluxo de mediação existente:

```typescript
// Após os transfers ERC-20 serem confirmados:

import { postMediationFeedback } from '@/lib/erc8004/reputation'
import { registerVerdictAsValidation } from '@/lib/erc8004/validation'

// Dentro da função que executa a mediação, após os transfers:
async function onMediationComplete(settlementResult: SettlementResult) {
  
  const agentId = BigInt(process.env.VEREDICT_AGENT_ID ?? '0')

  // 1. Postar reputação onchain
  await postMediationFeedback(walletClient, agentId, {
    contractId: settlementResult.contractRef,
    settlementTxHash: settlementResult.txHash,
    clientSatisfaction: 100,
    resolutionTimeMs: settlementResult.durationMs,
    disputeType: settlementResult.disputeType,
  })

  // 2. Registrar veredito como evidência verificável
  await registerVerdictAsValidation(walletClient, agentId, {
    contractRef: settlementResult.contractRef,
    evidence: settlementResult.evidenceItems,
    settlement: {
      clientAmount: settlementResult.clientAmount,
      developerAmount: settlementResult.developerAmount,
      txHashes: settlementResult.txHashes,
    },
    reasoning: settlementResult.mediatorReasoning,
  })
}
```

