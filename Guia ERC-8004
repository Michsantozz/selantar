## PASSO 6 — Script de setup inicial (rodar uma vez)

**Onde:** `/scripts/register-agent.ts`

```typescript
import { createWalletClient, http } from 'viem'
import { privateKeyToAccount } from 'viem/accounts'
import { baseSepolia } from 'viem/chains'
import { registerVeredictAgent } from '../lib/erc8004/identity'

async function main() {
  const account = privateKeyToAccount(process.env.AGENT_PRIVATE_KEY as `0x${string}`)
  
  const walletClient = createWalletClient({
    account,
    chain: baseSepolia,
    transport: http(),
  })

  // A URL pública onde o agent.json estará acessível
  const agentJsonUrl = 'https://veredict.xyz/agent.json'

  const agentId = await registerVeredictAgent(walletClient, agentJsonUrl)
  
  console.log('\n✅ Setup completo!')
  console.log('Adicionar ao .env:')
  console.log(`VEREDICT_AGENT_ID=${agentId.toString()}`)
  console.log('\nAtualizar agent.json com o agentId:', agentId.toString())
}

main().catch(console.error)
```

