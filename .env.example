# Synthesis Hackathon
SYNTHESIS_API_KEY=
SYNTHESIS_PARTICIPANT_ID=
SYNTHESIS_TEAM_ID=

# Google AI (Gemini — used by mediator + client agents)
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenRouter (contract analysis)
OPENROUTER_API_KEY=

# ERC-8004 — fill after running: npx tsx scripts/register-agent.ts
SELANTAR_AGENT_ID=2122

# Agent wallet (never commit the real value)
AGENT_PRIVATE_KEY=

# Client wallet (for ERC-8004 feedback — must be different from agent)
CLIENT_PRIVATE_KEY=

# MetaMask Delegations (optional — enables delegation settlement path)
USE_DELEGATION=false
PIMLICO_API_KEY=

# Locus USDC payments (optional — enables Locus settlement path)
USE_LOCUS=false
LOCUS_API_KEY=

# OpenClaw WhatsApp notifications (optional — delivers mediation events via WhatsApp)
OPENCLAW_HOOKS_URL=http://127.0.0.1:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_NOTIFY_TO=
